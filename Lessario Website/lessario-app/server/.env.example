# Environment variables — NEVER commit this file
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
# Get this from: MongoDB Atlas → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/lessario?retryWrites=true&w=majority

# JWT Secret — used to sign authentication tokens
# Generate a strong random string (64+ chars)
JWT_SECRET=replace_this_with_a_very_long_random_secret_string_at_least_64_characters

# Server port
PORT=5000

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173

# Google OAuth Client ID (Step 5 — add later)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
